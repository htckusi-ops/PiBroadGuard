<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>PiBroadGuard Report – {{ device.manufacturer }} {{ device.model }}</title>
<style>
  body { font-family: Arial, sans-serif; font-size: 0.82rem; max-width: 1100px; margin: 0 auto; padding: 1.5rem; color: #1e293b; }
  h1 { font-size: 1.3rem; color: #0f172a; border-bottom: 3px solid #3b82f6; padding-bottom: 0.4rem; margin-bottom: 1rem; }
  h2 { font-size: 1.05rem; color: #1e40af; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  h3 { font-size: 0.95rem; color: #1e293b; }
  p { margin: 0.3rem 0; }
  table { width: 100%; border-collapse: collapse; margin: 0.6rem 0; font-size: 0.8rem; }
  th { background: #1e40af; color: white; padding: 0.35rem 0.5rem; text-align: left; }
  td { padding: 0.28rem 0.5rem; border-bottom: 1px solid #e2e8f0; }
  tr:nth-child(even) td { background: #f8fafc; }
  .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: bold; font-size: 0.75rem; }
  .green { background: #dcfce7; color: #166534; }
  .yellow { background: #fef9c3; color: #854d0e; }
  .orange { background: #ffedd5; color: #9a3412; }
  .red { background: #fee2e2; color: #991b1b; }
  .critical { background: #fecaca; color: #991b1b; }
  .high { background: #fed7aa; color: #9a3412; }
  .medium { background: #fef9c3; color: #854d0e; }
  .low { background: #dcfce7; color: #166534; }
  .info { background: #dbeafe; color: #1e40af; }
  .finding { border: 1px solid #cbd5e1; border-radius: 6px; padding: 0.7rem 1rem; margin: 0.7rem 0; }
  .finding-header { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.4rem; flex-wrap: wrap; }
  .kev-warning { background: #fef2f2; border: 1px solid #fca5a5; border-radius: 4px; padding: 0.4rem 0.8rem; margin: 0.4rem 0; font-size: 0.8rem; }
  .recommendations { background: #f0f9ff; border-left: 3px solid #3b82f6; padding: 0.4rem 0.8rem; margin: 0.4rem 0; font-size: 0.8rem; }
  .meta { color: #64748b; font-size: 0.78rem; }
  /* Nmap output: white background, monospace, bordered – print-friendly */
  .nmap-output { font-family: 'Courier New', Courier, monospace; font-size: 0.72rem; background: #ffffff; color: #1e293b; border: 1px solid #cbd5e1; padding: 0.8rem 1rem; border-radius: 4px; overflow-x: auto; white-space: pre; page-break-inside: auto; line-height: 1.45; }
  code { font-family: 'Courier New', Courier, monospace; background: #f1f5f9; padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.8em; }
  @media print { .no-print { display: none; } }
  /* PDF / print page-break rules */
  h1, h2 { page-break-after: avoid; }
  h3 { page-break-after: avoid; }
  table { page-break-inside: auto; }
  tr { page-break-inside: avoid; page-break-after: auto; }
  thead { display: table-header-group; }
  .finding { page-break-inside: avoid; }
  @page { margin: 1.5cm 2cm; }
</style>
</head>
<body>

<h1>PiBroadGuard – Broadcast Device Security Assessment Report</h1>

<table>
  <tr><th>Gerät</th><td>{{ device.manufacturer }} {{ device.model }}</td></tr>
  <tr><th>Assessment-ID</th><td>#{{ assessment.id }}</td></tr>
  <tr><th>Datum</th><td>{{ assessment.created_at | date }}</td></tr>
  <tr><th>Reviewer</th><td>{{ assessment.reviewer or "ausstehend" }}</td></tr>
  <tr><th>Entscheid</th><td><strong>{{ assessment.decision | decision_label }}</strong></td></tr>
  <tr><th>Gesamtbewertung</th><td>
    <span class="badge {{ assessment.overall_rating or 'info' }}">{{ assessment.overall_rating | rating_label }}</span>
  </td></tr>
</table>

<h2>Executive Summary</h2>
<p>{{ assessment.summary or "Kein Summary vorhanden." }}</p>

<h3>Score-Übersicht</h3>
<table>
  <tr><th>Dimension</th><th>Score</th><th>Standard-Referenz</th></tr>
  <tr><td>Technisch</td><td>{{ assessment.technical_score }}/100</td><td>IEC 62443-4-2 / NIST SP 800-82</td></tr>
  <tr><td>Betrieb</td><td>{{ assessment.operational_score }}/100</td><td>IEC 62443-3-2 / NIST SP 800-82 Ch.4</td></tr>
  <tr><td>Kompensation</td><td>{{ assessment.compensation_score }}/100</td><td>IEC 62443: Compensating Countermeasures</td></tr>
  <tr><td>Lifecycle</td><td>{{ assessment.lifecycle_score }}/100</td><td>IEC 62443-4-1 / NIST SP 800-30</td></tr>
  <tr><td>Hersteller</td><td>{{ assessment.vendor_score }}/100</td><td>IEC 62443-4-1 PSIRT / SDL</td></tr>
</table>

<h2>Angewandte Methodik und Standards</h2>
<table>
  <tr><th>Standard</th><th>Relevanz</th></tr>
  <tr><td><strong>IEC 62443-3-2</strong></td><td>Security Risk Assessment für OT/ICS-Systeme (Risikobewertung, Zonen)</td></tr>
  <tr><td><strong>IEC 62443-4-2</strong></td><td>Component Security Requirements (Gerätebewertung)</td></tr>
  <tr><td><strong>IEC 62443-4-1</strong></td><td>Secure Product Development Lifecycle (SDL/PSIRT-Bewertung)</td></tr>
  <tr><td><strong>NIST SP 800-82r3</strong></td><td>Guide to OT Security (OT-Risikomanagement)</td></tr>
  <tr><td><strong>NIST SP 800-115</strong></td><td>Technical Guide to Security Testing (Scan-Methodik)</td></tr>
  <tr><td><strong>NIST SP 800-30r1</strong></td><td>Risk Assessment Methodology (Impact × Likelihood)</td></tr>
  <tr style="background:#f8f4ff"><td><strong>EBU R143</strong></td><td>Security Requirements für vernetzte Broadcast-Geräte (Hardening-Katalog)</td></tr>
  <tr style="background:#f8f4ff"><td><strong>EBU R148</strong></td><td>Mindesttests für Netzwerk-Sicherheit von Media Equipment</td></tr>
  <tr style="background:#f8f4ff"><td><strong>EBU R160 S1</strong></td><td>Leitfaden für Basis- und vertiefte Schwachstellenprüfung an Broadcast-Geräten</td></tr>
  <tr style="background:#f8f4ff"><td><strong>AMWA BCP-003-01</strong></td><td>TLS für NMOS APIs (Certificate Provisioning)</td></tr>
  <tr style="background:#f8f4ff"><td><strong>AMWA BCP-003-02</strong></td><td>Authorization für NMOS APIs (OAuth2/JWT via IS-10)</td></tr>
  <tr style="background:#f8f4ff"><td><strong>SMPTE ST 2110</strong></td><td>Professional Media over IP (Referenzrahmen)</td></tr>
  <tr style="background:#f8f4ff"><td><strong>SMPTE ST 2059</strong></td><td>Synchronisation und PTP in Broadcast-Netzwerken</td></tr>
  <tr style="background:#f8f4ff"><td><strong>JT-NM TR-1001-1</strong></td><td>Erwartetes Verhalten von ST-2110-Media-Nodes</td></tr>
</table>
<p class="meta">
  Scan-Tool: Nmap {{ nmap_version }}, Profil: {{ scan_profile_label }}{% if scan_profile_description %} – {{ scan_profile_description }}{% endif %}<br>
  {% if nmap_command %}<code style="font-size:0.85rem">{{ nmap_command }}</code><br>{% endif %}
  {% if auth %}Scan-Autorisierung: {{ auth.authorized_by_name }} ({{ auth.authorized_by_role }}), erteilt am {{ auth.authorization_date | date }}<br>{% endif %}
  CVE-Datenquellen: NIST NVD API v2, CISA KEV Catalog, CISA ICS Advisories, FIRST EPSS<br>
  Bewertungsdatum: {{ assessment.created_at | date }}
</p>

<h2>Gerätestammdaten</h2>
<table>
  <tr><th>Hersteller</th><td>{{ device.manufacturer }}</td></tr>
  <tr><th>Modell</th><td>{{ device.model }}</td></tr>
  <tr><th>Gerätetyp</th><td>{{ device.device_type }}</td></tr>
  <tr><th>IP-Adresse</th><td>{{ device.ip_address }}</td></tr>
  <tr><th>Firmware</th><td>{{ device.firmware_version or "—" }}</td></tr>
  <tr><th>Standort</th><td>{{ device.location or "—" }}</td></tr>
  <tr><th>Netzwerksegment</th><td>{{ device.network_segment or "—" }}</td></tr>
  <tr><th>Produktionskritikalität</th><td>{{ device.production_criticality or "—" }}</td></tr>
  <tr><th>Verantwortliches Team</th><td>{{ device.owner_team or "—" }}</td></tr>
</table>

<h2>Scan-Resultate ({{ scan_results | length }} Ports)</h2>
{% if scan_results %}
<table>
  <tr><th>Port</th><th>Protokoll</th><th>Service</th><th>Produkt</th><th>Version</th><th>Status</th></tr>
  {% for s in scan_results %}
  <tr>
    <td>{{ s.port }}</td><td>{{ s.protocol }}</td>
    <td>{{ s.service_name or "—" }}</td>
    <td>{{ s.service_product or "—" }}</td>
    <td>{{ s.service_version or "—" }}</td>
    <td>{{ s.state }}</td>
  </tr>
  {% endfor %}
</table>
{% else %}
<p>Keine Scan-Resultate vorhanden.</p>
{% endif %}

<h2>Findings ({{ findings | length }})</h2>
<p class="meta" style="margin-bottom:0.8rem;">
  Findings werden in zwei Schritten erzeugt:
  <strong>(1) Regelwerk-Matching</strong> – Nmap-Scan-Ergebnisse (offene Ports/Services) werden gegen die YAML-Regeln geprüft und erzeugen automatische Findings.
  <strong>(2) CVE/KEV/EPSS-Anreicherung</strong> – Für erkannte Produkt- und Versionsinformationen wird die NIST NVD API v2 abgefragt; gefundene CVEs werden mit CISA KEV (aktiv ausgenutzt?) und FIRST EPSS (Exploit-Wahrscheinlichkeit) abgeglichen. Anreicherung erfolgt nur im Online-Modus; bei Offline-Betrieb werden Regelwerk-Findings ohne CVE-Daten angezeigt.
</p>
{% for f in findings %}
<div class="finding">
  <div class="finding-header">
    <span class="badge {{ f.severity or 'info' }}">{{ f.severity | upper }}</span>
    <strong>{{ f.title }}</strong>
    {% if f.cve_id %}
    <a href="https://nvd.nist.gov/vuln/detail/{{ f.cve_id }}" target="_blank" rel="noopener"
       style="font-family:monospace;font-size:0.75rem;background:#1e293b;color:#fff;padding:2px 6px;border-radius:4px;text-decoration:none;">{{ f.cve_id }}</a>
    {% endif %}
    {% if f.cvss_score %}
    <span style="font-size:0.75rem;font-weight:bold;padding:2px 6px;border-radius:4px;
      {% set cs = f.cvss_score | float %}
      {% if cs >= 9.0 %}background:#dc2626;color:#fff;
      {% elif cs >= 7.0 %}background:#ea580c;color:#fff;
      {% elif cs >= 4.0 %}background:#ca8a04;color:#fff;
      {% else %}background:#16a34a;color:#fff;{% endif %}
      " title="CVSS Base Score (NIST NVD)">CVSS {{ "%.1f" | format(f.cvss_score | float) }}</span>
    {% endif %}
    {% if f.kev_listed %}<span class="badge red" title="Diese Schwachstelle wird aktiv ausgenutzt – CISA Known Exploited Vulnerabilities">⚠️ CISA KEV</span>{% endif %}
    {% if f.cwe_id %}
    <a href="https://cwe.mitre.org/data/definitions/{{ f.cwe_id | replace('CWE-', '') }}.html" target="_blank" rel="noopener"
       style="font-size:0.75rem;background:#ede9fe;color:#6d28d9;padding:2px 6px;border-radius:4px;text-decoration:none;">{{ f.cwe_id }}</a>
    {% endif %}
  </div>
  <p><strong>Befund:</strong> {{ f.evidence or "—" }}</p>
  <p><strong>Risiko:</strong> {{ f.description or "—" }}</p>
  <p><strong>Broadcast-Kontext:</strong> {{ f.broadcast_context or "—" }}</p>

  <div class="recommendations">
    <strong>Empfehlung (Regelwerk):</strong> {{ f.recommendation or "—" }}
    {% if f.kev_listed %}
    <div class="kev-warning">
      ⚠️ <strong>Aktiv ausgenutzt (CISA KEV):</strong> {{ f.kev_required_action or "Patch gemäss Herstelleranweisung anwenden." }}
      <br><small><a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog" target="_blank" rel="noopener">→ CISA KEV Catalog</a></small>
    </div>
    {% endif %}
    {% if f.nvd_solution %}
    <p><strong>NVD-Empfehlung:</strong> {{ f.nvd_solution }}
    {% if f.cve_id %}<br><small><a href="https://nvd.nist.gov/vuln/detail/{{ f.cve_id }}" target="_blank" rel="noopener">→ NVD: {{ f.cve_id }}</a></small>{% endif %}</p>
    {% endif %}
    {% if f.vendor_advisory_url %}<p><strong>Hersteller-Advisory:</strong> <a href="{{ f.vendor_advisory_url }}" target="_blank" rel="noopener">{{ f.vendor_advisory_url }}</a></p>{% endif %}
    {% if f.cwe_recommendation %}
    <p><strong><a href="https://cwe.mitre.org/data/definitions/{{ f.cwe_id | replace('CWE-', '') }}.html" target="_blank" rel="noopener">{{ f.cwe_id }}</a>:</strong> {{ f.cwe_recommendation }}</p>
    {% endif %}
  </div>

  <p><strong>Status:</strong> {{ f.status | status_label }}
  {% if f.compensating_control_description %} | <strong>Kompensation:</strong> {{ f.compensating_control_description }}{% endif %}
  </p>
</div>
{% endfor %}

<h2>Entscheid</h2>
<p><strong>{{ assessment.decision | decision_label }}</strong></p>
<p>{{ assessment.decision_notes or "—" }}</p>
<p>Re-Assessment fällig: {{ assessment.reassessment_due | date }}</p>

{% if action_items %}
<h2>Plan of Action and Milestones (POA&M)</h2>
<table>
  <tr><th>Priorität</th><th>Massnahme</th><th>Verantwortlich</th><th>Fällig</th><th>Status</th></tr>
  {% for item in action_items %}
  <tr>
    <td>{{ item.priority | prio_label }}</td>
    <td>{{ item.title }}</td>
    <td>{{ item.responsible_team or "—" }}</td>
    <td>{{ item.due_date | date }}</td>
    <td>{{ item.status | status_label }}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

{% if nmap_raw_output %}
<h2>Anhang: Nmap-Scan-Output</h2>
<p class="meta">Profil: <strong>{{ scan_profile_label }}</strong>{% if nmap_command %} &nbsp;·&nbsp; Befehl: <code>{{ nmap_command }}</code>{% endif %}<br>
Nur offene Ports aufgeführt. Vollständiges Scan-XML liegt im System (Audit-Log) gespeichert.</p>
<pre class="nmap-output">{{ nmap_raw_output | e }}</pre>
{% endif %}

<hr>
<p class="meta">Report generiert am {{ generated_at.strftime("%d.%m.%Y %H:%M") }} UTC durch PiBroadGuard v1.0</p>

</body>
</html>
